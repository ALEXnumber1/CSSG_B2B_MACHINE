# Credenciales de Supabase
# Renombra este archivo a .env.local y rellena los datos
VITE_SUPABASE_URL=https://tu-proyecto.supabase.co
VITE_SUPABASE_ANON_KEY=eyJh... (tu clave anon)

# Email Nurturing (Resend)
# Obtener en: https://resend.com/api-keys
VITE_RESEND_API_KEY=re_... (tu API key de Resend)
